# ─────────────────────────────────────────────────────────────────────────
# Specifinance — Variables de entorno
# Configúralas en: Vercel → tu proyecto → Settings → Environment Variables
# (NO subas un archivo .env real al repositorio; este es solo de ejemplo.)
# ─────────────────────────────────────────────────────────────────────────

# === Base de datos (Neon Postgres) ===
# Se crea sola al conectar la integración Neon desde Vercel:
#   Vercel → Storage → Create Database → Neon → Connect to Project.
# La integración inyecta DATABASE_URL / POSTGRES_URL automáticamente,
# así que normalmente NO tienes que pegar este valor a mano.
DATABASE_URL="postgresql://usuario:clave@host.neon.tech/dbname?sslmode=require"

# === Acceso al panel de administrador (CRM) ===
ADMIN_EMAIL="specifinance@gmail.com"
ADMIN_PASSWORD="cambia-esta-clave-por-una-segura"

# Secreto para firmar el token de sesión del admin.
# Pon cualquier cadena larga y aleatoria (mínimo 32 caracteres).
ADMIN_TOKEN_SECRET="genera-una-cadena-larga-y-aleatoria-aqui"

# === Frontend (deben empezar con VITE_ para ser visibles en el navegador) ===
# Enlace de agendamiento Calendly que se abre tras enviar el formulario.
VITE_CALENDLY_URL="https://calendly.com/specifinance/consultoria"

# (Opcional) Solo si algún día sirves la API desde otro dominio distinto al sitio.
# VITE_API_BASE="https://specifinance.com"

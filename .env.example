# ─────────────────────────────────────────────────────────────────────────
# Specifinance — Variables de entorno
# Configúralas en: Vercel → tu proyecto → Settings → Environment Variables
# (NO subas un archivo .env real al repositorio; este es solo de ejemplo.)
# ─────────────────────────────────────────────────────────────────────────

# === Almacenamiento (Google Sheets vía Apps Script) ===
# Despliega google-apps-script.gs como "Aplicación web" en tu Google Sheet y
# pega aquí la URL /exec que te entrega. SHEETS_SECRET debe COINCIDIR con el
# SECRET del Apps Script. Sin SHEETS_WEBHOOK_URL el sitio corre en modo demo.
SHEETS_WEBHOOK_URL="https://script.google.com/macros/s/XXXXXXXXXXXX/exec"
SHEETS_SECRET="una-cadena-larga-y-aleatoria-igual-a-la-del-apps-script"

# === Acceso al panel de administrador (CRM) ===
ADMIN_EMAIL="tucorreo@ejemplo.com"
ADMIN_PASSWORD="cambia-esta-clave-por-una-segura"

# Secreto para firmar el token de sesión del admin (mínimo 32 caracteres).
# Si no lo defines, se usa ADMIN_PASSWORD como respaldo.
ADMIN_TOKEN_SECRET="genera-una-cadena-larga-y-aleatoria-aqui"

# === Frontend (deben empezar con VITE_ para ser visibles en el navegador) ===
# Enlace de agendamiento Calendly que se abre tras enviar el formulario.
VITE_CALENDLY_URL="https://calendly.com/tu-usuario/consultoria"

# (Opcional) Solo si algún día sirves la API desde otro dominio distinto al sitio.
# VITE_API_BASE="https://specifinance.com"
